    "@phosphor-icons/react": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@fontsource-variable/geist": "5.2.9",
    "@phosphor-icons/react": "2.1.10",
    "@storybook/addon-a11y": "10.4.5",
