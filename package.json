{
  "name": "surf-design-system",
  "version": "0.0.0",
  "private": true,
  "description": "SURFnet design system — React (shadcn/Base UI) and Angular (Spartan) component packages in a Turborepo monorepo.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,css,html}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "turbo": "2.9.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,css,html}": "prettier --write"
  }
}
