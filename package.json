{
  "name": "curve",
  "version": "0.0.0",
  "private": true,
  "description": "Curve — React (shadcn/Base UI) and Angular (Spartan) component packages in a Turborepo monorepo.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "sync:figma": "jiti scripts/sync-figma.ts",
    "dev": "turbo run dev",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,css,html}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@figma/rest-api-spec": "0.40.0",
    "@types/node": "^22.19.21",
    "dotenv": "17.4.2",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "turbo": "2.9.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,css,html}": "prettier --write"
  }
}
