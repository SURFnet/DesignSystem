# Credentials for `pnpm sync:figma` (scripts/sync-figma.mjs).
# Copy to .env and fill in. .env is git-ignored.

# Figma personal access token with file_variables:read scope.
# Create one at https://www.figma.com/settings under "Personal access tokens".
FIGMA_TOKEN=

# Figma file key — the segment after /design/ (or /file/) in the file URL:
# https://www.figma.com/design/<FIGMA_FILE_ID>/Your-File-Name
FIGMA_FILE_ID=
